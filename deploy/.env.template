# CoinBot 환경 변수 템플릿
# 사용법: cp deploy/.env.template /home/ubuntu/coinbot/.env
#         vi /home/ubuntu/coinbot/.env  ← 실제 값으로 채운 뒤
#         chmod 600 /home/ubuntu/coinbot/.env

# Upbit API 키
UPBIT_ACCESS_KEY=여기에_Access_Key_입력
UPBIT_SECRET_KEY=여기에_Secret_Key_입력

# 거래 마켓 목록 (CSV, 생략 시 Config.h 기본값 KRW-ADA,KRW-TRX,KRW-XRP 사용)
UPBIT_MARKETS=KRW-XRP,KRW-ADA,KRW-TRX
